{
  "name": "group4-peft-node-sink",
  "config": {
    "connector.class": "org.neo4j.connectors.kafka.sink.Neo4jConnector",
    "tasks.max": "1",
    "topics": "peft.cpg.nodes",
    "consumer.override.auto.offset.reset": "latest",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "neo4j.uri": "neo4j://neo4j:7687",
    "neo4j.authentication.type": "BASIC",
    "neo4j.authentication.basic.username": "neo4j",
    "neo4j.authentication.basic.password": "password123",
    "neo4j.cypher.bind-value-as": "__value",
    "neo4j.cypher.bind-value-as-event": "false",
    "neo4j.cypher.topic.peft.cpg.nodes": "MERGE (n:CPGNode {id: __value.element_id}) SET n.kind = __value.kind, n.label = __value.label, n.file_path = __value.file_path, n.repo = __value.repo, n.commit_sha = __value.commit_sha, n.updated_at = datetime()"
  }
}
